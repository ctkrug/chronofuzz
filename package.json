{
  "name": "chronofuzz",
  "version": "0.1.0",
  "private": true,
  "description": "Paste a date-handling function, run it against a curated battery of real date/time landmines.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
